# StadiumPulse AI — Environment Configuration Example
# Copy this file to '.env' and configure your desired AI engine (Gemini or local Ollama)

# --- Option A: Google Gemini API (Default) ---
# Go to https://aistudio.google.com to get a key
GEMINI_API_KEY=your_gemini_api_key_here

# --- Option B: Local Offline Inference with Ollama ---
# Set to 'true' to use a locally running Ollama model instead of Gemini API
USE_OLLAMA=true
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=gemma2:2b

# Port configuration
PORT=3000
